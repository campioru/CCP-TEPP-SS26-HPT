#!/bin/bash -l
#SBATCH --job-name=ddot-R
#SBATCH --time=1-0:00:00
#SBATCH --nodes=1
#SBATCH --ntasks-per-node=32
#SBATCH --mem=90G
#SBATCH --nodelist=wizard23

# Your HPC system will probably differ.

module reset
module load gompi/2023a
module load R/4.3.2-gfbf-2023a


echo "dot_product_doMPI.R version"

Rscript dot_product_doMPI.R 10000000 1

Rscript dot_product_doMPI.R 10000000 4

Rscript dot_product_doMPI.R 10000000 8

Rscript dot_product_doMPI.R 10000000 16

exit

